{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/((?!video-script-|video-cutscene-|video-mr-x-pursuit-route|video-true-ending-checklist|soundtrack-|art-)[^/]+)\\.html",
      "destination": "/$1/",
      "permanent": true
    },
    {
      "source": "/ko/((?!video-script-|video-cutscene-|video-mr-x-pursuit-route|video-true-ending-checklist|soundtrack-|art-)[^/]+)\\.html",
      "destination": "/ko/$1/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(sitemap.xml|rss.xml|robots.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/search-index.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        },
        {
          "key": "Content-Encoding",
          "value": "identity"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    }
  ]
}
